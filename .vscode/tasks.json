{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Backend",
			"type": "shell",
			"command": "uvicorn backend.app.main:app --reload",
			"group": "build",
			"isBackground": true
		},
		{
			"label": "Frontend",
			"type": "shell",
			"command": "npm run dev",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"isBackground": true
		},
		{
			"label": "Ruff Check",
			"type": "shell",
			"command": "ruff check ."
		},
		{
			"label": "Ruff Format",
			"type": "shell",
			"command": "ruff format ."
		},
		{
			"label": "Pytest",
			"type": "shell",
			"command": "pytest"
		},
		{
			"label": "Alembic Upgrade",
			"type": "shell",
			"command": "alembic upgrade head"
		},
		{
			"label": "Docker Compose Up",
			"type": "shell",
			"command": "docker compose up -d"
		},
		{
			"label": "Docker Compose Down",
			"type": "shell",
			"command": "docker compose down"
		}
	]
}
